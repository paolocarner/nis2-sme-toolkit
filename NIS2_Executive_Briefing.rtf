\par \pard\plain \s0\rtlch\af6\afs22\alang1081 \ltrch\lang1033\langfe2052\hich\af4\loch\ql\widctlpar\sb0\sa0\ltrpar\ql\widctlpar\hyphpar0\sb0\sa0\ltrpar\cf0\f4\fs22\lang1033\kerning0\dbch\af6\langfe2052\qc\sb0\sa240{\rtlch\afs24\ai \ltrch\loch\fs24\i\loch
