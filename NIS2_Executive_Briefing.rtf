\par \pard\plain \s37\rtlch\af6\afs22\alang1081 \ltrch\lang1033\langfe2052\hich\af4\loch\ql\widctlpar\sb0\sa0\ltrpar\ql\widctlpar\hyphpar0\sb0\sa0\ltrpar\cf0\f4\fs22\lang1033\kerning0\dbch\af6\langfe2052{\listtext\pard\plain  \u8226\'95\tab}\ilvl0\ls1 \fi-360\li720\lin720{\loch
